{
    "Version": "2012-10-17",
    "Statement": [
        {
            "Sid": "Statement1",
            "Effect": "Allow",
            "Action": [
                "iam:CreateUser",
                "Iam:GetUser",
                "iam:ListUsers",
                "iam:UpdateLoginProfile",
                "iam:CreateLoginProfile",
                "iam:GetLoginProfile",
                "iam:ListGroups",
                "iam:AttachUserPolicy"
            ],
            "Resource": "*"
        },
        {
            "Sid": "Statement2",
            "Effect": "Deny",
            "Action": [
                "iam:DeleteUser",
                "iam:DeletePolicy",
                "iam:CreateAccesskey"
            ],
            "Resource": "*"
        }
    ]
}